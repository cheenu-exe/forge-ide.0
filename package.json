{
  "name": "forgeide",
  "version": "0.1.0",
  "private": true,
  "rocketCritical": {
    "dependencies": [
      "next",
      "react",
      "react-dom",
      "@dhiwise/component-tagger",
      "@tailwindcss/typography",
      "recharts"
    ],
    "devDependencies": [
      "typescript",
      "@types/node",
      "@types/react",
      "@types/react-dom",
      "@typescript-eslint/eslint-plugin",
      "@typescript-eslint/parser",
      "eslint-config-next",
      "tailwindcss",
      "autoprefixer",
      "postcss",
      "eslint",
      "prettier",
      "@netlify/plugin-nextjs"
    ],
    "scripts": [
      "dev",
      "build",
      "start",
      "lint",
      "lint:fix",
      "format",
      "serve",
      "type-check"
    ],
    "warning": "🚨 CRITICAL: DO NOT REMOVE OR MODIFY ABOVE DEPENDENCIES - Required for Next.js 15 TypeScript app functionality"
  },
  "scripts": {
    "dev": "next dev -p 4028",
    "clean": "node -e \"const fs = require('fs'); ['.next', 'tsconfig.tsbuildinfo'].forEach((target) => { if (fs.existsSync(target)) { fs.rmSync(target, { recursive: true, force: true, maxRetries: 5, retryDelay: 100 }); } });\"",
    "build": "npm run clean && next build",
    "start": "next start -p 4028",
    "backend:dev": "uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload",
    "backend:start": "uvicorn backend.main:app --host 0.0.0.0 --port 8000",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md,json}\"",
    "serve": "next start -p 4028",
    "type-check": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@dhiwise/component-tagger": "^1.0.15",
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.6.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.55.1",
    "next": "15.5.18",
    "react": "19.0.3",
    "react-dom": "19.0.3",
    "react-resizable-panels": "^2.1.7",
    "readline": "^1.3.0",
    "recharts": "^2.15.2",
    "sonner": "^1.7.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@netlify/plugin-nextjs": "^5.11.1",
    "@types/node": "^20",
    "@types/react": "19.0.3",
    "@types/react-dom": "19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "autoprefixer": "10.4.2",
    "eslint": "^9",
    "eslint-config-next": "^15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "postcss": "8.4.8",
    "prettier": "^3.5.3",
    "tailwindcss": "3.4.6",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
