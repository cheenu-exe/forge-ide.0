html { scroll-behavior: smooth; height: 100%; }

body { background-color: var(--background); color: var(--foreground); font-=
family: var(--font-sans); -webkit-font-smoothing: antialiased; height: 100%=
; overflow: hidden; }

#__next { height: 100%; }

