eHighlightBackground); box-sizing: border-box; border: 1px solid var(--vsco=
de-editor-rangeHighlightBorder); }

.monaco-editor.hc-black .rangeHighlight, .monaco-editor.hc-light .rangeHigh=
light { border-style: dotted; }

