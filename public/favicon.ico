.monaco-editor { position: relative; overflow: visible; text-size-adjust: 1=
00%; color: var(--vscode-editor-foreground); background-color: var(--vscode=
-editor-background); overflow-wrap: initial; }

.monaco-editor-background { background-color: var(--vscode-editor-backgroun=
d); }

