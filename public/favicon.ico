de-editor-background)); color: var(--vscode-button-foreground, var(--vscode=
-editor-foreground)); border-width: 1px; border-style: solid; border-color:=
 var(--vscode-contrastBorder); border-radius: 2px; padding: 4px; cursor: po=
inter; }

.mtkoverflow:hover { background-color: var(--vscode-button-hoverBackground)=
; }

